# ─── Session ──────────────────────────────────────────
# Random 32+ character password for session encryption (REQUIRED in production)
NUXT_SESSION_PASSWORD=

# ─── Database ─────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/chatlive

# ─── Encryption ──────────────────────────────────────
# Optional: separate key for message encryption (falls back to NUXT_SESSION_PASSWORD)
# MESSAGE_ENCRYPTION_KEY=

# ─── OAuth: GitHub ───────────────────────────────────
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
